    "video_variation_presets": {
      "_note": "Preset variasi khusus untuk generate video — mempertimbangkan motion consistency, face lock, dan temporal coherence.",

      "options": [
        {
          "name": "Character_Idle_Loop_Series",
          "id": "Seri Loop Idle Karakter",
          "description": "Seri video ambient loop dengan kondisi berbeda — karakter idle dalam mood dan waktu berbeda. Untuk wallpaper atau sosmed.",
          "generator_type": "video",
          "platform_recommended": ["kling", "pika", "runway"],
          "randomizable_elements": [
            "scene_core.time_of_day",
            "scene_core.weather",
            "scene_core.season",
            "lighting.preset",
            "atmosphere.visual_style.color_palette",
            "motion.environment_motion.elements",
            "motion.environment_motion.wind_effect"
          ],
          "fixed_elements": {
            "subjects.primary_subject.expression_emotion.primary_emotion": "serenity",
            "motion.subject_motion.primary_motion": "idle_breathing",
            "motion.motion_intensity": "still",
            "temporal_sequence.loop": true
          },
          "rules": [
            {
              "rule_id": "V01_time",
              "target_element": "scene_core.time_of_day",
              "variation_type": "sequential",
              "options": ["golden_hour", "blue_hour", "midnight", "dawn"],
              "probability": 1.0
            },
            {
              "rule_id": "V02_lighting",
              "target_element": "lighting.preset",
              "variation_type": "conditional",
              "conditions": [
                { "if": "time_of_day == 'golden_hour'", "then": "golden_hour" },
                { "if": "time_of_day == 'blue_hour'", "then": "blue_hour" },
                { "if": "time_of_day == 'midnight'", "then": "moonlight" },
                { "if": "time_of_day == 'dawn'", "then": "sunrise_atmospheric" }
              ],
              "probability": 1.0
            },
            {
              "rule_id": "V03_wind",
              "target_element": "motion.environment_motion.wind_effect",
              "variation_type": "weighted_random",
              "options": [
                { "value": "very_light_breeze", "weight": 0.4 },
                { "value": "light_breeze", "weight": 0.4 },
                { "value": "dead_calm", "weight": 0.2 }
              ],
              "probability": 1.0
            }
          ],
          "batch_config": {
            "count": 4,
            "naming_pattern": "{char}_idle_{time_of_day}_loop_{n}",
            "fps": 24,
            "duration_sec": 5,
            "loop": true
          }
        },
        {
          "name": "Dynamic_Action_Shots",
          "id": "Shot Aksi Dinamis",
          "description": "Seri video action dengan shot dan gerakan berbeda — untuk battle, parkour, atau power showcase.",
          "generator_type": "video",
          "platform_recommended": ["runway", "kling"],
          "randomizable_elements": [
            "composition.camera.shot_type",
            "composition.camera.angle",
            "motion.camera_movement.type",
            "motion.subject_motion.primary_motion",
            "motion.subject_motion.speed",
            "motion.motion_intensity",
            "lighting.preset"
          ],
          "fixed_elements": {
            "subjects.primary_subject.dressing_room.active_outfit": "outfit_battle",
            "subjects.primary_subject.expression_emotion.primary_emotion": "determination",
            "temporal_sequence.loop": false
          },
          "rules": [
            {
              "rule_id": "V01_shot",
              "target_element": "composition.camera.shot_type",
              "variation_type": "sequential",
              "options": ["WS", "MS", "MCU", "CU"],
              "probability": 1.0
            },
            {
              "rule_id": "V02_camera_move",
              "target_element": "motion.camera_movement.type",
              "variation_type": "random_pick",
              "options": ["dolly", "orbit", "handheld_follow", "static"],
              "probability": 0.8
            },
            {
              "rule_id": "V03_motion_intensity",
              "target_element": "motion.motion_intensity",
              "variation_type": "sequential",
              "options": ["moderate", "active", "intense", "explosive"],
              "probability": 1.0,
              "depends_on": "V01_shot"
            },
            {
              "rule_id": "V04_speed",
              "target_element": "motion.subject_motion.speed",
              "variation_type": "conditional",
              "conditions": [
                { "if": "motion_intensity == 'moderate'", "then": "real_time" },
                { "if": "motion_intensity == 'active'", "then": "real_time" },
                { "if": "motion_intensity == 'intense'", "then": "real_time" },
                { "if": "motion_intensity == 'explosive'", "then": "slow_motion" }
              ],
              "probability": 0.9
            }
          ],
          "batch_config": {
            "count": 4,
            "naming_pattern": "{char}_action_{shot}_{n}",
            "fps": 24,
            "duration_sec": 6
          }
        },
        {
          "name": "Portrait_Reveal_Series",
          "id": "Seri Reveal Portrait",
          "description": "Seri video reveal shot tunggal dengan camera movement berbeda — untuk intro karakter.",
          "generator_type": "video",
          "platform_recommended": ["runway", "kling", "hailuo"],
          "randomizable_elements": [
            "motion.camera_movement.type",
            "motion.camera_movement.direction",
            "motion.camera_movement.speed",
            "lighting.preset",
            "atmosphere.visual_style.color_palette"
          ],
          "fixed_elements": {
            "composition.camera.shot_type": "MS",
            "subjects.primary_subject.pose.base_pose": "standing_composed",
            "motion.subject_motion.primary_motion": "idle_subtle_sway",
            "temporal_sequence.loop": false
          },
          "rules": [
            {
              "rule_id": "V01_camera_type",
              "target_element": "motion.camera_movement.type",
              "variation_type": "sequential",
              "options": ["dolly", "orbit", "static", "crane_jib"],
              "probability": 1.0
            },
            {
              "rule_id": "V02_direction",
              "target_element": "motion.camera_movement.direction",
              "variation_type": "conditional",
              "conditions": [
                { "if": "camera_type == 'dolly'", "then": "forward" },
                { "if": "camera_type == 'orbit'", "then": "clockwise" },
                { "if": "camera_type == 'static'", "then": null },
