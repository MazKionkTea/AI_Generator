{
  "_readme": "Library variations v2 — ekspansi dari v1 dengan fokus pada: (1) dependency map antar field, (2) forbidden combinations per genre, (3) variation templates khusus video, (4) production profiles untuk use case nyata, (5) QA framework terintegrasi. Gunakan bersama variations_v1.json — v2 adalah referensi lanjutan, bukan pengganti.",
  "_version": "2.0",
  "_use_alongside": "variations_v1.json — v1 berisi foundations (types, probability, basic presets). v2 berisi advanced patterns.",

  "variations": {

    "field_dependency_map": {
      "_note": "Peta ketergantungan antar field — jika field A berubah, field mana yang harus ikut berubah agar output tetap kohesif. Gunakan ini untuk merancang conditional rules yang benar.",

      "primary_chains": {
        "_note": "Chain perubahan yang paling sering dibutuhkan dalam produksi.",
        "chains": [
          {
            "name": "time_of_day_chain",
            "trigger": "scene_core.time_of_day",
            "must_follow": [
              { "field": "lighting.preset", "relationship": "direct_match", "note": "Golden hour → golden_hour preset. Midnight → moonlight atau neon. Dawn → sunrise_atmospheric." },
              { "field": "lighting.key_light.color.temperature", "relationship": "derived", "note": "Siang = 5500K daylight. Golden hour = 2700K warm. Blue hour = 7000K cool. Midnight = 3200K tungsten jika ada lampu." },
              { "field": "atmosphere.visual_style.color_palette", "relationship": "suggested", "note": "Golden hour → warm_golden. Midnight → neon_dark atau monochrome_blue. Dawn → pastel_dream." },
              { "field": "scene_core.lighting_condition", "relationship": "derived", "note": "Night time → low_light atau artificial_light. Noon → harsh_direct. Overcast bisa kapan saja." }
            ],
            "rule_order": ["scene_core.time_of_day", "lighting.preset", "lighting.key_light.color.temperature", "atmosphere.visual_style.color_palette"]
          },
          {
            "name": "weather_chain",
            "trigger": "scene_core.weather",
            "must_follow": [
              { "field": "environment.weather_climate.precipitation", "relationship": "direct_match", "note": "Rain → light_rain atau heavy_rain. Snow → snowfall. Clear → none." },
              { "field": "lighting.key_light.quality", "relationship": "derived", "note": "Overcast → very_soft diffused. Clear → hard_direct. Rain → soft_diffused." },
              { "field": "atmosphere.visual_style.color_palette", "relationship": "suggested", "note": "Rain → desaturated_muted atau monochrome_blue. Storm → blood_black. Clear → warm_golden atau natural." },
              { "field": "motion.environment_motion.wind_effect", "relationship": "derived", "note": "Storm → gale_force. Light rain → steady_breeze. Clear → light_breeze atau none." }
            ],
            "rule_order": ["scene_core.weather", "environment.weather_climate.precipitation", "lighting.key_light.quality", "atmosphere.visual_style.color_palette", "motion.environment_motion.wind_effect"]
          },
          {
            "name": "outfit_chain",
            "trigger": "subjects.primary_subject.dressing_room.active_outfit",
            "must_follow": [
              { "field": "subjects.primary_subject.pose.base_pose", "relationship": "suggested", "note": "Battle outfit → combat stance. Formal → standing composed. Casual → relaxed. Festival → playful." },
              { "field": "subjects.primary_subject.pose.energy_level", "relationship": "derived", "note": "Battle → high atau explosive. Formal → controlled. Casual → low atau idle." },
              { "field": "motion.subject_motion.cloth_physics", "relationship": "derived", "note": "Heavy armor → minimal. Long dress formal → gentle_sway. Battle cape → dramatic_flow." }
            ],
            "rule_order": ["active_outfit", "pose.base_pose", "pose.energy_level", "cloth_physics"]
          },
          {
            "name": "emotion_chain",
            "trigger": "subjects.primary_subject.expression_emotion.primary_emotion",
            "must_follow": [
              { "field": "subjects.primary_subject.expression_emotion.micro_expressions", "relationship": "derived", "note": "Grief → tears forming, quivering lip. Anger → jaw clenched, flared nostrils. Joy → crinkled eyes, raised cheeks." },
              { "field": "subjects.primary_subject.pose.energy_level", "relationship": "suggested", "note": "Fear → tense atau collapsed. Determination → controlled high. Joy → open elevated." },
              { "field": "atmosphere.emotional_tone", "relationship": "should_mirror", "note": "Emosi karakter harus resonan dengan mood scene — grief + melancholic, joy + hopeful." },
              { "field": "lighting.key_light.color.temperature", "relationship": "suggested", "note": "Warm light amplifies joy/hope. Cool light amplifies grief/dread." }
            ],
            "rule_order": ["primary_emotion", "micro_expressions", "energy_level", "atmosphere.emotional_tone", "lighting.key_light.color.temperature"]
          },
          {
            "name": "shot_type_chain",
            "trigger": "composition.camera.shot_type",
            "must_follow": [
              { "field": "composition.camera.lens.focal_length", "relationship": "derived", "note": "ECU/CU → 85–135mm. MS → 50mm. FS/WS → 24–35mm. EWS → 16–24mm." },
              { "field": "composition.camera.lens.aperture", "relationship": "suggested", "note": "CU portrait → f/1.4–f/2.8 wide open. WS landscape → f/8–f/11 deep focus." },
              { "field": "composition.framing.head_room", "relationship": "derived", "note": "CU → tight head room. WS → generous head room atau frame dalam environment." },
              { "field": "composition.spatial_layers.foreground_element", "relationship": "optional", "note": "WS/EWS sering butuh foreground element untuk depth. CU tidak perlu." }
            ],
            "rule_order": ["shot_type", "focal_length", "aperture", "head_room"]
          }
        ]
      },

      "conflict_pairs": {
        "_note": "Kombinasi field yang akan menghasilkan output inkohesif jika digunakan bersamaan — avoid these.",
        "pairs": [
          { "field_a": "scene_core.time_of_day = midnight", "field_b": "lighting.preset = harsh_noon", "conflict": "Waktu malam tapi pencahayaan siang hari — kontradiksi fisika." },
          { "field_a": "scene_core.weather = heavy_storm", "field_b": "atmosphere.emotional_tone = serene", "conflict": "Badai besar tapi mood tenang — visual dan atmosfer bertentangan." },
          { "field_a": "atmosphere.visual_style.art_movement = photorealism", "field_b": "atmosphere.visual_style.art_movement = anime_modern", "conflict": "Tidak bisa dua gaya utama sekaligus — pilih satu." },
          { "field_a": "subjects.primary_subject.pose.base_pose = lying_down", "field_b": "motion.camera_movement.type = orbit", "conflict": "Orbit shot pada karakter berbaring menghasilkan angle aneh." },
          { "field_a": "composition.camera.shot_type = ECU", "field_b": "environment.location.primary = vast_open_landscape", "conflict": "Extreme close-up pada wajah tidak menampilkan landscape sama sekali — waste of environment detail." },
          { "field_a": "scene_core.era = medieval_fantasy", "field_b": "environment.technology.level = cyberpunk_high_tech", "conflict": "Era dan teknologi bertentangan kecuali ini memang diesel/steampunk hybrid yang disengaja." },
          { "field_a": "atmosphere.spatial_quality.openness = suffocating", "field_b": "composition.camera.shot_type = EWS", "conflict": "EWS secara visual menampilkan ruang luas — bertentangan dengan feel suffocating." },
          { "field_a": "motion.motion_intensity = explosive", "field_b": "subjects.primary_subject.expression_emotion.primary_emotion = serenity", "conflict": "Gerakan ekstrem tapi ekspresi damai — tidak natural." },
          { "field_a": "lighting.preset = studio_three_point", "field_b": "scene_core.setting_type = outdoor_wilderness", "conflict": "Studio lighting di lokasi outdoor wilderness — tidak believable." },
          { "field_a": "technical.post_processing.color_grading = noir_monochrome", "field_b": "atmosphere.visual_style.color_palette = neon_cyberpunk", "conflict": "Monochrome dan neon colorful — saling membatalkan." }
        ]
      }
    },

