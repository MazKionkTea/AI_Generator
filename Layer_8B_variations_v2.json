    "qa_framework": {
      "_note": "Framework Quality Assurance terintegrasi dalam batch — definisi kriteria accept/reject dan scoring per output.",

      "acceptance_criteria": {
        "_note": "Kondisi minimum yang harus terpenuhi agar output diterima ke approved/.",
        "mandatory": [
          {
            "criterion": "face_visible",
            "description": "Wajah karakter harus terlihat dan tidak terpotong (kecuali memang shot non-portrait)",
            "auto_check": "Jika shot_type adalah CU/MCU/MS tapi wajah tidak terlihat → reject"
          },
          {
            "criterion": "race_consistent",
            "description": "Ras karakter harus konsisten dengan identity_anchor — tidak boleh drift ke ras lain",
            "auto_check": "Verifikasi visual terhadap reference_images"
          },
          {
            "criterion": "no_extra_limbs",
            "description": "Tidak ada extra limb, jari tambahan, atau distorsi anatomi parah",
            "auto_check": "AI anatomy detection jika tersedia"
          },
          {
            "criterion": "no_text_artifacts",
            "description": "Tidak ada garbled text atau gibberish text dalam gambar kecuali memang ada signage",
            "auto_check": "OCR check pada area text"
          },
          {
            "criterion": "composition_intentional",
            "description": "Subjek tidak terpotong secara tidak sengaja — sesuai dengan shot_type yang diminta",
            "auto_check": "Verifikasi bahwa subjek ada dalam frame sesuai shot_type"
          }
        ],
        "preferred": [
          { "criterion": "lighting_cohesive", "description": "Arah dan kualitas cahaya konsisten dengan time_of_day dan lighting.preset" },
          { "criterion": "atmosphere_matching", "description": "Mood visual sesuai dengan emotional_tone yang didefinisikan" },
          { "criterion": "outfit_complete", "description": "Seluruh outfit terlihat — tidak ada bagian yang terpotong secara aneh" },
          { "criterion": "no_identity_drift", "description": "Wajah identik atau sangat mirip dengan reference_images" }
        ]
      },

      "quality_scoring": {
        "_note": "Rubrik penilaian 1–10 per dimensi. Total skor / jumlah dimensi = overall score.",
        "dimensions": [
          {
            "dimension": "face_accuracy",
            "weight": 3.0,
            "description": "Seberapa akurat wajah terhadap identity_anchor dan reference_images",
            "score_guide": {
              "9_10": "Identik dengan reference — semua fitur match",
              "7_8": "Sangat mirip — minor variation yang acceptable",
              "5_6": "Mirip tapi ada perbedaan yang terasa",
              "3_4": "Sama ras dan hair color tapi wajah berbeda",
              "1_2": "Karakter yang berbeda sama sekali"
            }
          },
          {
            "dimension": "technical_quality",
            "weight": 2.0,
            "description": "Kualitas teknis — sharpness, anatomy, no artifacts",
            "score_guide": {
              "9_10": "Sempurna — tidak ada cacat teknis",
              "7_8": "Sangat baik — cacat minor tidak mengganggu",
              "5_6": "Acceptable — ada cacat tapi masih usable",
              "3_4": "Ada masalah teknis yang mengganggu",
              "1_2": "Cacat berat — tidak usable"
            }
          },
          {
            "dimension": "atmosphere_match",
            "weight": 1.5,
            "description": "Seberapa sesuai suasana dengan yang didefinisikan di atmosphere dan lighting",
            "score_guide": {
              "9_10": "Atmosphere persis sesuai spec",
              "7_8": "Atmosphere sangat dekat spec",
              "5_6": "Atmosphere cukup sesuai",
              "3_4": "Atmosphere sedikit berbeda dari intended",
              "1_2": "Atmosphere sama sekali berbeda"
            }
          },
          {
            "dimension": "composition_quality",
            "weight": 1.0,
            "description": "Kualitas komposisi — framing, balance, intentionality",
            "score_guide": {
              "9_10": "Komposisi excellent — sesuai spec dan secara artistik kuat",
              "7_8": "Komposisi baik",
              "5_6": "Komposisi acceptable",
              "3_4": "Komposisi lemah",
              "1_2": "Komposisi poor — perlu re-generate"
            }
          },
          {
            "dimension": "outfit_accuracy",
            "weight": 1.5,
            "description": "Akurasi outfit terhadap definisi di dressing_room",
            "score_guide": {
              "9_10": "Outfit sesuai 100% dengan definisi",
              "7_8": "Outfit sangat mirip — minor variation",
              "5_6": "Outfit ada tapi ada perbedaan",
              "3_4": "Outfit sangat berbeda dari definisi",
              "1_2": "Outfit salah sama sekali"
            }
          }
        ],
        "scoring_formula": "weighted_average = sum(score * weight) / sum(weights)",
        "approval_thresholds": {
          "auto_approve": "overall >= 8.5 DAN face_accuracy >= 8",
          "manual_review": "overall 6.5–8.4 ATAU face_accuracy 6–7.9",
          "auto_reject": "overall < 6.5 ATAU face_accuracy < 6 ATAU mandatory_criterion_failed"
        }
      },

